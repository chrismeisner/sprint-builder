{
  "description": "Component contract: shared names and token usage. Figma and web reference these so 'Button/primary' means the same thing.",
  "components": [
    {
      "id": "button",
      "name": "Button",
      "variants": [
        { "id": "primary", "label": "Primary" },
        { "id": "secondary", "label": "Secondary" },
        { "id": "ghost", "label": "Ghost" }
      ],
      "tokens": {
        "background": { "primary": "foreground", "secondary": "surface.strong", "ghost": "transparent" },
        "text": { "primary": "background", "secondary": "text.primary", "ghost": "text.primary" },
        "borderRadius": "borderRadius.control",
        "paddingX": "spacing.4",
        "paddingY": "spacing.2"
      }
    },
    {
      "id": "card",
      "name": "Card",
      "variants": [
        { "id": "default", "label": "Default" }
      ],
      "tokens": {
        "background": "surface.card",
        "stroke": "stroke.muted",
        "borderRadius": "borderRadius.card",
        "shadow": "boxShadow.card",
        "padding": "spacing.4"
      }
    },
    {
      "id": "input",
      "name": "Input",
      "variants": [
        { "id": "default", "label": "Default" },
        { "id": "error", "label": "Error" }
      ],
      "tokens": {
        "background": "surface.card",
        "border": { "default": "stroke.muted", "error": "semantic.danger" },
        "borderRadius": "borderRadius.control",
        "text": "text.primary",
        "placeholder": "text.muted"
      }
    }
  ]
}
