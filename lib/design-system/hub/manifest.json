{
  "name": "form-intake design system hub",
  "version": "0.1.0",
  "description": "Single source of truth for tokens and component contracts. Synced from Figma; consumed by Style Dictionary and the app.",
  "source": {
    "figma": {
      "fileKey": "YOUR_FIGMA_FILE_KEY",
      "sync": "Figma → hub (variables API); hub → CSS/App via Style Dictionary"
    }
  },
  "tokenSets": {
    "order": ["primitives", "sizing", "semantic-light", "semantic-dark"],
    "paths": {
      "primitives": "../tokens/primitives.json",
      "sizing": "../tokens/sizing.json",
      "semantic-light": "../tokens/semantic-light.json",
      "semantic-dark": "../tokens/semantic-dark.json"
    }
  },
  "outputs": {
    "css": {
      "primitives": "app/generated-tokens.css",
      "semantic-light": "app/generated-semantic-light.css",
      "semantic-dark": "app/generated-semantic-dark.css"
    },
    "tailwind": "lib/design-system/tailwind-tokens.json"
  },
  "componentSpecs": "./component-specs.json"
}
